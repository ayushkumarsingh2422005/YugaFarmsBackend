{
  "kind": "collectionType",
  "collectionName": "blog_sections",
  "info": {
    "singularName": "blog-section",
    "pluralName": "blog-sections",
    "displayName": "BlogSection"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Content": {
      "type": "richtext",
      "required": true
    },
    "Title": {
      "type": "string",
      "required": true
    },
    "sluge": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "CoverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    }
  }
}
